      "routeKeys": {},
      "namedRegex": "^/api/auth(?:/)?$"
    },
    {
      "page": "/api/contact",
      "regex": "^/api/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/contact(?:/)?$"
    },
    {
      "page": "/api/events",
      "regex": "^/api/events(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/events(?:/)?$"
    },
    {
      "page": "/api/posts",
      "regex": "^/api/posts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/posts(?:/)?$"
    },
    {
      "page": "/api/profile",
      "regex": "^/api/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/profile(?:/)?$"
    },
    {
      "page": "/api/team",
      "regex": "^/api/team(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/team(?:/)?$"
    },
    {
      "page": "/auth",
      "regex": "^/auth(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth(?:/)?$"
    },
    {
      "page": "/esemenyeink",
      "regex": "^/esemenyeink(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/esemenyeink(?:/)?$"
    },
    {
      "page": "/kapcsolat",
      "regex": "^/kapcsolat(?:/)?$",
      "routeKeys": {},
